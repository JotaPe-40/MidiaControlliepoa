{
  "name": "togglevmix",
  "version": "0.1.0",
  "private": true,
  "description": "Painel desktop para controlar os gatilhos do Holyrics ligados ao vMix",
  "main": "src/main.js",
  "type": "commonjs",
  "scripts": {
    "prestart": "node scripts/ensure-electron.js",
    "start": "electron .",
    "predev": "node scripts/ensure-electron.js",
    "dev": "electron .",
    "postinstall": "node scripts/ensure-electron.js",
    "check": "node --check src/main.js && node --check src/renderer.js",
    "build": "electron-builder --win portable"
  },
  "devDependencies": {
    "electron": "^42.2.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.midiacontrolliepoa.togglevmix",
    "productName": "ToggleVMix",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "config.json",
      "package.json"
    ],
    "portable": {
      "artifactName": "ToggleVMix-Portable-${version}.${ext}"
    },
    "win": {
      "target": ["portable"],
      "signAndEditExecutable": false
    }
  },
  "license": "MIT"
}